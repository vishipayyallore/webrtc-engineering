{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "demos/**/*.ts",
    "demos/**/*.tsx",
    "projects/**/*.ts",
    "projects/**/*.tsx",
    "tools/**/*.ts"
  ],
  "exclude": ["node_modules", ".archive", "**/node_modules"]
}
